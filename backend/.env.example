# Base de données PostgreSQL
DATABASE_URL="postgresql://asm_user:asm_password@localhost:5432/asm_location"

# JWT Secrets (générer avec: openssl rand -base64 64)
JWT_SECRET="votre_secret_jwt_tres_long_et_securise_a_changer_en_production"
JWT_REFRESH_SECRET="votre_secret_refresh_jwt_different_du_premier_a_changer"
JWT_EXPIRY="15m"
REFRESH_EXPIRY="7d"

# Serveur
PORT=5000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# Fichiers uploadés
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880

# Puppeteer (génération PDF)
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD="false"
