# ================================================================
# DOMAINES
# ================================================================
FRONTEND_DOMAIN=asm-location.innosft.com
BACKEND_DOMAIN=asm-api.innosft.com

# ================================================================
# LET'S ENCRYPT (SSL)
# ================================================================
# Mettre votre email pour recevoir les alertes d'expiration
LETSENCRYPT_EMAIL=votre-email@example.com

# ================================================================
# BASE DE DONNÉES PostgreSQL
# ================================================================
DB_USER=asm_user
DB_PASSWORD=CHANGER_MOT_DE_PASSE_FORT_ICI
DB_NAME=asm_location

# ================================================================
# JWT SECRETS (générer avec: openssl rand -base64 64)
# ================================================================
JWT_SECRET=CHANGER_SECRET_JWT_TRES_LONG_ET_ALEATOIRE
JWT_REFRESH_SECRET=CHANGER_SECRET_REFRESH_JWT_DIFFERENT_DU_PREMIER
JWT_EXPIRY=15m
REFRESH_EXPIRY=7d
